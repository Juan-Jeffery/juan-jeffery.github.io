/* css/style.css */
body {
  margin: 0;
  font-family: "Fira Code", monospace;
  color: #111;
  background-color: #fff;
  line-height: 1.6;
}

h1, h2, h3 {
  font-family: 'Press Start 2P', cursive;
  text-transform: uppercase;
}

/* 統一的導覽列樣式 */
nav {
  position: fixed;
  top: 20px;
  left: 30px;
  z-index: 1000;
  background: white;
  padding: 6px 12px;
  border-radius: 4px;
  border: 2px solid #000;
  box-shadow: 3px 3px 0px rgba(0, 0, 0, 0.1);
}

nav a {
  margin-right: 20px;
  text-decoration: none;
  font-weight: bold;
  color: #111;
  font-size: 0.8em;
  padding-bottom: 4px;
  border-bottom: 3px solid transparent;
  transition: all 0.2s;
}

nav a:hover {
  color: #007acc;
  border-bottom: 3px solid #007acc; /* 你要求的底線 */
}

/* 當前頁面的底線標記 */
nav a.active {
  border-bottom: 3px solid #111;
}